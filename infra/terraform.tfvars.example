# terraform.tfvars.example
# Copy this file to terraform.tfvars and fill in the values.
# Never commit terraform.tfvars — it contains sensitive data.

# AWS region to deploy into
aws_region = "us-east-1"

# EC2 instance type.
# t3.small (2 vCPU, 2 GB RAM) is sufficient for staging.
# Use t3.medium or larger for production workloads.
instance_type = "t3.small"

# Application and environment names (used as resource name prefixes)
app_name    = "opendatamask"
environment = "staging"

# SSH public key content (paste the contents of your ~/.ssh/id_rsa.pub or similar)
# Generate a new key pair with: ssh-keygen -t ed25519 -C "opendatamask-deploy"
public_key_material = "ssh-ed25519 AAAA... your-public-key-here"

# CIDR block allowed to SSH into the server.
# Restrict to your IP address in production: "203.0.113.42/32"
allowed_ssh_cidr = "0.0.0.0/0"

# Root EBS volume size in GiB (default 20 GB covers OS + Docker images + DB data)
volume_size_gb = 20
